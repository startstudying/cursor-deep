APP_NAME=cursor-deep-plus
HOST=0.0.0.0
PORT=8787

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PUBLIC_MODEL_NAME=cursor-proxy
MODEL_MAP_JSON={"cursor-proxy":"gpt-4o-mini","cursor-fast":"gpt-4.1-mini"}

GATEWAY_API_KEY=local-dev-token
REQUEST_TIMEOUT_SECONDS=600
LOG_DB_PATH=storage/chat_logs.db
MAX_LOGGED_BODY_CHARS=12000
DROP_FIELDS=
UPSTREAM_CHAT_PATH=/chat/completions
UPSTREAM_RESPONSES_PATH=/responses
UPSTREAM_SUPPORTS_RESPONSES=true
ENABLE_DESKTOP_ROUTES=true
