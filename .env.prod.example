APP_NAME=cursor-deep-plus
HOST=0.0.0.0
PORT=8787

OPENAI_BASE_URL=https://your-upstream.example.com/v1
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini

PUBLIC_MODEL_NAME=cursor-proxy
MODEL_MAP_JSON={"cursor-proxy":"gpt-4o-mini"}

GATEWAY_API_KEY=replace-with-long-random-token
REQUEST_TIMEOUT_SECONDS=600
LOG_DB_PATH=/data/chat_logs.db
MAX_LOGGED_BODY_CHARS=12000
DROP_FIELDS=
UPSTREAM_CHAT_PATH=/chat/completions
UPSTREAM_RESPONSES_PATH=/responses
UPSTREAM_SUPPORTS_RESPONSES=true
ENABLE_DESKTOP_ROUTES=false
